    "GET /api/TodoLists — Get all Todo Lists",
    "POST /api/TodoLists — Create a new Todo List",
    "PUT /api/TodoLists/{id} — Update a Todo List",
    "DELETE /api/TodoLists/{id} — Delete a Todo List",
    "GET /api/TodoItems — Get Todo Items with pagination",
    "POST /api/TodoItems — Create a Todo Item",
    "PUT /api/TodoItems/{id} — Update a Todo Item",
    "DELETE /api/TodoItems/{id} — Delete a Todo Item",
    "GET /api/WeatherForecasts — Get weather forecasts",
    "IApplicationDbContext — Application layer DB abstraction",
    "IIdentityService — User identity abstraction",
    "BaseEntity / BaseAuditableEntity / BaseEvent — Domain base classes",
